#!/usr/bin/env bash

red=$(tput setaf 1)
yellow=$(tput setaf 3)
green=$(tput setaf 2)
reset=$(tput sgr0)

# Catch TODO comments
export BLOCKER=0
if grep -r -q --include="*.lua" "print"; then
  printf "%10s\n" "${red}print${reset} ${yellow}found in your comments. Resolve before pushing.${reset}"
  grep -r --include="*.lua" -n "print"
  echo ""
  BLOCKER=1
fi

for keyword in TODO FIXME FIX BUG; do
  if grep -r -q --include="*.lua" "${keyword}:"; then
    printf "%10s\n" "${red}${keyword}${reset} ${yellow}found in your comments. Resolve before pushing.${reset}"
    grep -r --include="*.lua" -n "${keyword}:"
    echo ""
    BLOCKER=1
  fi
done

if [ "${BLOCKER}" == 1 ]; then
  exit 1
fi

# # Confirm basic tests pass

if ! luacheck .; then
  printf "%10s\n" "${red}luacheck failed. Commit aborted.${reset}"
  exit 1
fi
